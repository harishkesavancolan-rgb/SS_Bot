# ─────────────────────────────────────────────────────────────
# Dockerfile.chat
# Handles: FastAPI chat API (question → retrieve → LLM → response)
# Lambda handler: api.chat.handler
# ─────────────────────────────────────────────────────────────

FROM python:3.11-slim

WORKDIR /app

RUN apt-get update && apt-get install -y \
    libpoppler-cpp-dev \
    poppler-utils \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Download the cross-encoder model at build time and bake it into the image
# This means Lambda containers start with the model already on disk
# No download on cold start → no timeout
# Model is saved to /app/hf_cache which is part of the image filesystem
# Download model at build time — baked into image
ENV HF_HOME=/app/hf_cache
RUN python -c "from sentence_transformers import CrossEncoder; CrossEncoder('cross-encoder/ms-marco-MiniLM-L-6-v2')"
# Copy both api/ and ingestion/
# api/ needs ingestion/store.py for DB connection
COPY ingestion/ ./ingestion/
COPY api/       ./api/

ENV PYTHONUNBUFFERED=1
ENV PYTHONDONTWRITEBYTECODE=1

CMD ["python", "-m", "awslambdaric", "api.chat.handler"]